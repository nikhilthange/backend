<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main w-full min-h-screen bg-zinc-900">
        <div class="form p-10 text-white">
            <form action="/create" method="post">
                <input class="block px-5 py-2 bg-zinc-800 w-full rounded-md" type="text" placeholder="Title goes in..." name="title">
                <textarea class="block px-5 py-2 bg-zinc-800 w-full rounded-md resize-none mt-2" placeholder="Write Your task details..." name="details"></textarea>
                <input class="mt-2 bg-blue-600 px-5 py-2 rounded-md" type="submit" value="Create a Task">
            </form>
        </div>
        <div class="tasks p-10 flex gap-3 flex-wrap ">
            <%if(files.length > 0) { %>
               <%files.forEach(function(val){ %>
                  <div class="task min-w-72 w-72 px-3 py-4 bg-zinc-800 rounded-md" >
                  <h1 class="text-white text-2xl tracking-tighter"><%= val %></h1>

                  <div class="w-full flex justify-between items-center mt-3">
                  <a class="text-blue-500 inline-block " href="/file/<%= val %>">Read More</a>
                  <a  class="text-zinc-500" href="/edit/<%= val %>">edit filename</a>
                  </div>
                  </div>

               <% }) %>

            <%}else{ %>
               <h3 class="text-zinc-600">No tasks yet</h3>
            <% } %>
           
        </div>
    </div>
</body>
</html>